{
  "AgentWorkflow": {
    "Tools": {
      "EnableRepoFileTools": true,
      "WorkspaceRoot": ".",
      "SqlServer": {
        "EnableQueryTool": false,
        "ConnectionString": "",
        "CommandTimeoutSeconds": 30,
        "StoredProcedureAllowlist": []
      },
      "Assets": {
        "EnableGenerateAssetTool": false,
        "OutputDirectory": "generated-assets"
      }
    },
    "Planner": {
      "Name": "planner",
      "FunctionDescription": "Break down user requests into concise plans in French, then provide clear actionable steps.",
      "Model": "gpt-5-nano",
      "ReasoningEffort": "minimal",
      "Verbosity": "low"
    },
    "Executor": {
      "Name": "executor",
      "FunctionDescription": "Execute technical/code-oriented requests in French with concise outputs.",
      "Model": "gpt-5-nano",
      "ReasoningEffort": "minimal",
      "Verbosity": "low"
    },
    "Workflow": {
      "MaxTurns": 8,
      "Retry": {
        "MaxAttempts": 3,
        "DelayMs": 400
      },
      "Timeouts": {
        "AgentSeconds": 90,
        "ToolSeconds": 45
      },
      "SessionMemory": {
        "Enabled": true,
        "Directory": ".sessions"
      },
      "Metrics": {
        "Enabled": true,
        "FilePath": ".metrics/workflow-metrics.jsonl"
      }
    }
  }
}
